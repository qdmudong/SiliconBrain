MERGE (n:Entity {name: "Orphan Rule"});
MERGE (n:Entity {name: "A rule that states that if a trait has no implementations, it should be considered an orphan."});
MERGE (n:Entity {name: "The orphan rule is used to ensure that traits are not left without any implementations."});
MERGE (n:Entity {name: "Trait Bound"});
MERGE (n:Entity {name: "A bound that restricts the types that can implement a trait."});
MERGE (n:Entity {name: "Trait bounds are implemented using a combination of methods and macros."});
MERGE (n:Entity {name: "Self Type"});
MERGE (n:Entity {name: "The type of the current object being referred to in a trait method."});
MERGE (n:Entity {name: "The self type is used to refer to the current object in a trait method."});
MERGE (n:Entity {name: "Default Value"});
MERGE (n:Entity {name: "A default value that can be provided when a trait method is called with no arguments."});
MERGE (n:Entity {name: "The default value is used to provide a default implementation for a trait method."});
MERGE (n:Entity {name: "Trait Method"});
MERGE (n:Entity {name: "A function that implements the behavior of a trait."});
MERGE (n:Entity {name: "Trait methods are implemented using a combination of methods and macros."});
